rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Regra para as pastas 'news' e 'gallery'
    //tester de deploy
    match /{folder}/{allPaths=**} {
      // Qualquer pessoa pode ler os arquivos.
      allow read: if true;
      // Apenas usuários autenticados podem escrever imagens de até 5MB.
      allow write: if request.auth != null
                   && (folder == 'news' || folder == 'gallery')
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}