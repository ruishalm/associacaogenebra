rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A coleção 'news' pode ser lida por qualquer um, mas só pode ser
    // escrita por usuários autenticados (administradores).
    match /news/{newsId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // A coleção 'users' contém dados de perfil.
    // Cada usuário só pode ler e escrever no seu próprio documento.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
  }
}